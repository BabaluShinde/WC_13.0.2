   <objecttype name="folder" class="wt.folder.SubFolder" resourceBundle="com.ptc.windchill.enterprise.folder.FolderActionResource">
      <!-- Expand/Collapse actions.  Used in the old-style table/tree in which structures can be "exploded"
           and "imploded" within the table itself (e.g., the "Network Folders" table/tree).
      -->

      <action name="explode" enabledwhensuspended="true" ajax="component">
        <command onClick="PTC.jca.expandAll (target, event, table)"/>
        <includeFilter name="HideForPCHolderContentTable"/>
